OPENAI_API_KEY=sk-d51d88d4e2c441c4a7efc42ca6712aec
OPENAI_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1
OPENAI_MODEL=qwen-plus

#EMBEDDING_MODEL_PATH=C:/Users/shizhuoyue/.cache/modelscope/hub/models/sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_MODEL_PATH=D:/pytnon_code/job_exe/3Hello_Agent/my-first-project-main/local_models/bge-small-zh-v1.5
# Session/auth settings for the website layer.
SESSION_TTL_HOURS=168
ALLOW_PUBLIC_REGISTRATION=false
SECURE_SESSION_COOKIES=false
SESSION_COOKIE_NAME=deepresearch_session

# Switch all structured storage together:
# - auto: use PostgreSQL when DATABASE_URL is set, otherwise SQLite
# - sqlite
# - postgresql
STORAGE_BACKEND=auto

# PostgreSQL DSN for checkpoint + long-term memory + hybrid sparse index.
DATABASE_URL=

#all-MiniLM-L6-v2的向量数据库
# SQLite files used when STORAGE_BACKEND resolves to sqlite.
SQLITE_STORAGE_DB_PATH=app_storage.db
AGENT_CHECKPOINT_DB_PATH=agent_checkpoint.db
#VECTOR_DB_DIR=./vector_db_storage

#bge-small-zh-v1.5
VECTOR_DB_DIR=./vector_db_bge_small_512

# To use PostgreSQL instead:
# 1. Install: pip install "psycopg[binary]" langgraph-checkpoint-postgres
# 2. Set STORAGE_BACKEND=postgresql
# 3. Set DATABASE_URL, for example:
# DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DBNAME
